# ──────────────────────────────────────────────────────────
# Antioquia Biodiversa — Variables de entorno
# Copiar este archivo como .env y completar los valores reales
# NUNCA subir el archivo .env al repositorio
# ──────────────────────────────────────────────────────────

# Conexiones a MongoDB Atlas (mismo cluster, dos bases de datos separadas)
# BD Biodiversidad: catálogo de 150 especies (estático, curado)
MONGODB_URI_BIO=mongodb+srv://<usuario>:<contrasena>@<cluster>.mongodb.net/biodiversidad?retryWrites=true&w=majority
# BD Comunidad: registros de programas JPL y Guarda Cuencas (crecen con el tiempo)
MONGODB_URI_COM=mongodb+srv://<usuario>:<contrasena>@<cluster>.mongodb.net/comunidad?retryWrites=true&w=majority

# Puerto del servidor (por defecto 3000)
PORT=3000

# Secreto para las sesiones del panel de administración
# Usar una cadena aleatoria larga en producción (min. 32 caracteres)
SESSION_SECRET=cambiar_por_valor_aleatorio_seguro

# Contraseña del panel de administración de curadores
ADMIN_PASSWORD=cambiar_por_contrasena_segura
